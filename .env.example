# ── Supabase ──────────────────────────────────────────────────────────────────
# Lấy ở: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Lấy ở: Project Settings > Database > Connection Pooling > Session mode > URI
# Ký tự đặc biệt trong password phải URL-encode (@ → %40, # → %23, v.v.)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# ── Session (EJS legacy server) ────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=<random-hex-string>

# ── OpenRouter AI ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3000       # EJS legacy server
API_PORT=3001   # Express REST API (backend/)
NODE_ENV=development

# ── URLs ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
