{
  "name": "kizuna-nihongo",
  "version": "2.0.0",
  "description": "Kizuna Nihongo - Japanese learning platform (monorepo)",
  "private": true,
  "scripts": {
    "ejs": "nodemon server.js",
    "api": "npm --prefix backend run dev",
    "react": "npm --prefix frontend run dev",
    "dev": "concurrently -n EJS,API,REACT -c red,cyan,green \"npm run ejs\" \"npm run api\" \"npm run react\"",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0"
  }
}
